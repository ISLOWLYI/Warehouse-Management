<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Участники склада</h1>
      <p class="text-gray-600 text-sm mt-1"><%= @warehouse.name %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "← Назад к складу", warehouse_path(@warehouse), class: "bg-gray-100 text-gray-700 px-4 py-2 rounded-md text-sm font-medium hover:bg-gray-200 transition" %>
    </div>
  </div>

  <!-- Invite Form -->
  <% if current_user.admin? %>
    <div class="bg-white rounded-xl shadow-md p-6 border border-gray-100 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Пригласить участника</h2>
      <%= form_with url: invite_warehouse_warehouse_users_path(@warehouse), method: :post, local: true, class: "flex flex-wrap gap-3 items-end", data: { turbo: false } do |f| %>
        <div class="flex-1 min-w-[200px]">
          <%= label_tag :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= email_field_tag :email, nil, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
        <div>
          <%= label_tag :role, "Роль", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= select_tag :role, options_for_select([["Работник", "worker"], ["Поставщик", "supplier"], ["Администратор", "admin"]]), class: "border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-blue-500" %>
        </div>
        <%= submit_tag "Пригласить", class: "bg-blue-600 text-white px-6 py-2 rounded-md font-medium hover:bg-blue-700 transition" %>
      <% end %>
    </div>
  <% end %>

  <!-- Members List -->
  <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Пользователь</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Роль</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Статус</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Действия</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-100">
          <% @warehouse_users.each do |wu| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-blue-700 font-bold text-sm"><%= wu.user&.name&.first || wu.user&.email&.first || "?" %></div>
                  <div>
                    <div class="text-sm font-medium text-gray-900"><%= wu.user&.name || "Ожидает регистрации" %></div>
                    <div class="text-xs text-gray-500"><%= wu.user&.email || wu.invitation_token %></div>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3">
                <% if current_user.admin? && wu.user != current_user %>
                  <%= form_with url: update_role_warehouse_warehouse_user_path(@warehouse, wu), method: :patch, local: true, class: "inline" do |f| %>
                    <%= select_tag :role, options_for_select([["Админ", "admin"], ["Работник", "worker"], ["Поставщик", "supplier"]], wu.role), onchange: "this.form.submit()", class: "text-sm border border-gray-300 rounded-md px-2 py-1" %>
                  <% end %>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= wu.admin? ? 'bg-purple-100 text-purple-800' : wu.worker? ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
                    <%= t("roles.#{wu.role}", default: wu.role) %>
                  </span>
                <% end %>
              </td>
              <td class="px-4 py-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= wu.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                  <%= wu.active? ? "Активен" : "Неактивен" %>
                </span>
              </td>
              <td class="px-4 py-3 text-right text-sm font-medium">
                <% if current_user.admin? && wu.user != current_user %>
                  <% if wu.active? %>
                    <%= link_to "Деактивировать", deactivate_warehouse_warehouse_user_path(@warehouse, wu), data: { turbo_method: :patch, turbo_confirm: "Деактивировать пользователя?" }, class: "text-yellow-600 hover:text-yellow-900 mr-3" %>
                  <% end %>
                  <%= link_to "Удалить", warehouse_warehouse_user_path(@warehouse, wu), data: { turbo_method: :delete, turbo_confirm: "Удалить пользователя из склада?" }, class: "text-red-600 hover:text-red-900" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @warehouse_users.empty? %>
      <div class="p-8 text-center text-gray-500">
        Пока нет участников.
      </div>
    <% end %>
  </div>
</div>
