<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <%= link_to "← Назад к товарам", warehouse_products_path(@warehouse), class: "text-blue-600 hover:underline text-sm" %>
  </div>

  <h1 class="text-3xl font-bold text-gray-900 mb-8">Новый товар</h1>

  <div class="bg-white rounded-xl shadow-md p-6 sm:p-8 border border-gray-100">
    <%= form_with model: [@warehouse, @product], local: true, class: "space-y-6", data: { turbo: false } do |f| %>
      <% if @product.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-md">
          <strong class="font-medium">Ошибки:</strong>
          <ul class="mt-1 list-disc list-inside text-sm">
            <% @product.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :sku, "Артикул", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :sku, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
        <div>
          <%= f.label :name, "Название", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :category, "Категория", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :category, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
        <div>
          <%= f.label :quantity, "Количество", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :quantity, min: 0, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
      </div>

      <div>
        <%= f.label :location, "Местоположение (отдел/стеллаж/место)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :location, placeholder: "1/2/3", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        <p class="text-xs text-gray-500 mt-1">Формат: номер_отдела/номер_стеллажа/номер_места</p>
      </div>

      <div>
        <%= f.label :status, "Статус", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :status, options_for_select([["Активен", "active"], ["Неактивен", "inactive"], ["Архив", "archived"]]), {}, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <%= f.submit "Создать товар", class: "flex-1 bg-blue-600 text-white py-3 px-6 rounded-md font-medium hover:bg-blue-700 transition duration-200" %>
        <%= link_to "Отмена", warehouse_products_path(@warehouse), class: "flex-1 text-center bg-gray-200 text-gray-800 py-3 px-6 rounded-md font-medium hover:bg-gray-300 transition duration-200" %>
      </div>
    <% end %>
  </div>
</div>
