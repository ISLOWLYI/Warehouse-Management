<div class="min-h-screen flex items-center justify-center bg-gray-100 px-4">
  <div class="max-w-md w-full bg-white rounded-lg shadow-md p-8">
    <h2 class="text-2xl font-bold text-center text-gray-800 mb-6">Вход в систему</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <div>
        <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#2F6B3F]" %>
      </div>

      <div>
        <%= f.label :password, "Пароль", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#2F6B3F]" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center">
          <%= f.check_box :remember_me, class: "h-4 w-4 text-[#2F6B3F] focus:ring-[#2F6B3F] border-gray-300 rounded" %>
          <%= f.label :remember_me, "Запомнить меня", class: "ml-2 block text-sm text-gray-900" %>
        </div>
      <% end %>

      <div>
        <%= f.submit "Войти", class: "w-full bg-[#2F6B3F] text-white py-2 px-4 rounded-md hover:bg-[#1e4d2e] transition duration-200 font-medium" %>
      </div>
    <% end %>

    <div class="mt-4 text-center text-sm text-gray-600 space-y-1">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
