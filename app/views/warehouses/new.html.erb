<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Настройка нового склада</h1>

  <div class="bg-white rounded-xl shadow-md p-6 sm:p-8 border border-gray-100">
    <%= form_with model: @warehouse, url: warehouses_path, local: true, class: "space-y-6", data: { turbo: false } do |f| %>
      <% if @warehouse.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-md">
          <strong class="font-medium">Ошибки:</strong>
          <ul class="mt-1 list-disc list-inside text-sm">
            <% @warehouse.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "Название склада", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#2F6B3F]" %>
      </div>

      <div>
        <%= f.label :owner_name, "Имя владельца", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :owner_name, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#2F6B3F]" %>
      </div>

      <div>
        <%= f.label :address, "Адрес", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :address, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#2F6B3F]" %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <%= f.label :area, "Площадь (м²)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :area, step: 0.1, min: 0, id: "warehouse_area", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#2F6B3F]" %>
        </div>
        <div>
          <%= f.label :racks_count, "Количество стеллажей", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :racks_count, min: 0, id: "warehouse_racks_count", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#2F6B3F]" %>
        </div>
        <div>
          <%= f.label :zones_count, "Количество зон", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :zones_count, min: 0, id: "warehouse_zones_count", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#2F6B3F]" %>
        </div>
      </div>

      <!-- Cost Estimate -->
      <div class="bg-[#FFD27F]/20 rounded-lg p-4 border border-[#FFD27F]/50">
        <h3 class="text-lg font-semibold text-[#2F6B3F] mb-2">Предварительная смета</h3>
        <div class="space-y-1 text-sm text-[#2F6B3F]">
          <p>Базовая настройка: <span class="font-medium">5 000 ₽</span></p>
          <p>Площадь: <span id="cost_area" class="font-medium">0 ₽</span></p>
          <p>Стеллажи: <span id="cost_racks" class="font-medium">0 ₽</span></p>
          <p>Зоны: <span id="cost_zones" class="font-medium">0 ₽</span></p>
          <div class="border-t border-[#FFD27F]/50 pt-2 mt-2">
            <p class="text-base font-bold">Итого настройка: <span id="cost_total">5 000 ₽</span></p>
            <p class="text-sm">Ежемесячная подписка: <span id="cost_monthly">1 000 ₽</span></p>
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <%= f.submit "Создать склад", class: "flex-1 bg-[#2F6B3F] text-white py-3 px-6 rounded-md font-medium hover:bg-[#1e4d2e] transition duration-200" %>
        <%= link_to "Отмена", warehouses_path, class: "flex-1 text-center bg-gray-200 text-gray-800 py-3 px-6 rounded-md font-medium hover:bg-gray-300 transition duration-200" %>
      </div>
    <% end %>
  </div>
</div>

<script>
(function() {
  const areaInput = document.getElementById('warehouse_area');
  const racksInput = document.getElementById('warehouse_racks_count');
  const zonesInput = document.getElementById('warehouse_zones_count');
  const costArea = document.getElementById('cost_area');
  const costRacks = document.getElementById('cost_racks');
  const costZones = document.getElementById('cost_zones');
  const costTotal = document.getElementById('cost_total');
  const costMonthly = document.getElementById('cost_monthly');

  function updateEstimate() {
    const area = parseFloat(areaInput.value) || 0;
    const racks = parseInt(racksInput.value) || 0;
    const zones = parseInt(zonesInput.value) || 0;

    const areaCost = Math.round(area * 50);
    const racksCost = racks * 500;
    const zonesCost = zones * 1000;
    const baseCost = 5000;
    const total = baseCost + areaCost + racksCost + zonesCost;
    const monthly = 1000 + (zones * 200) + (racks * 50);

    costArea.textContent = areaCost.toLocaleString('ru-RU') + ' ₽';
    costRacks.textContent = racksCost.toLocaleString('ru-RU') + ' ₽';
    costZones.textContent = zonesCost.toLocaleString('ru-RU') + ' ₽';
    costTotal.textContent = total.toLocaleString('ru-RU') + ' ₽';
    costMonthly.textContent = monthly.toLocaleString('ru-RU') + ' ₽';
  }

  areaInput.addEventListener('input', updateEstimate);
  racksInput.addEventListener('input', updateEstimate);
  zonesInput.addEventListener('input', updateEstimate);
  updateEstimate();
})();
</script>
