<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Карта склада: <%= @warehouse.name %></h1>
    <%= link_to "← Назад к складу", warehouse_path(@warehouse), class: "text-blue-600 hover:underline" %>
  </div>

  <div class="bg-white rounded-xl shadow-md p-6 border border-gray-100 overflow-x-auto">
    <div class="min-w-max">
      <div class="grid gap-2" style="grid-template-columns: repeat(<%= @zones + 1 %>, minmax(80px, 1fr));">
        <!-- Header row -->
        <div class="p-2 text-center text-xs font-bold text-gray-400"></div>
        <% (1..@zones).each do |zone| %>
          <div class="p-2 text-center text-sm font-bold text-gray-700 bg-gray-50 rounded-t-md">Отдел <%= zone %></div>
        <% end %>

        <% (1..@racks).each do |rack| %>
          <div class="p-2 text-center text-sm font-bold text-gray-700 bg-gray-50 rounded-l-md flex items-center justify-center">Стеллаж <%= rack %></div>
          <% (1..@zones).each do |zone| %>
            <div class="relative bg-gray-50 border border-gray-200 rounded-md p-2 h-20 flex flex-col items-center justify-center hover:bg-blue-50 transition cursor-pointer cell" data-zone="<%= zone %>" data-rack="<%= rack %>">
              <span class="text-xs text-gray-400"><%= zone %>/<%= rack %></span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-6 bg-blue-50 rounded-lg p-4 border border-blue-100">
    <h3 class="text-sm font-semibold text-blue-900 mb-2">Легенда</h3>
    <div class="flex flex-wrap gap-4 text-sm">
      <div class="flex items-center gap-2"><div class="w-4 h-4 bg-gray-50 border border-gray-200 rounded"></div> <span>Свободно</span></div>
      <div class="flex items-center gap-2"><div class="w-4 h-4 bg-blue-200 border border-blue-400 rounded"></div> <span>Выделено</span></div>
      <div class="flex items-center gap-2"><div class="w-4 h-4 bg-green-200 border border-green-400 rounded"></div> <span>Есть товар</span></div>
    </div>
  </div>
</div>

<script>
(function() {
  const cells = document.querySelectorAll('.cell');
  const urlParams = new URLSearchParams(window.location.search);
  const highlightZone = urlParams.get('zone');
  const highlightRack = urlParams.get('rack');
  const highlightSpot = urlParams.get('spot');

  cells.forEach(cell => {
    const zone = cell.dataset.zone;
    const rack = cell.dataset.rack;

    if (highlightZone && highlightRack && zone === highlightZone && rack === highlightRack) {
      cell.classList.remove('bg-gray-50');
      cell.classList.add('bg-blue-200', 'border-blue-400');
      if (highlightSpot) {
        const spotLabel = document.createElement('span');
        spotLabel.className = 'text-lg font-bold text-blue-800 mt-1';
        spotLabel.textContent = 'Место ' + highlightSpot;
        cell.appendChild(spotLabel);
      }
    }
  });
})();
</script>
